# Exam Grader Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# CORE APPLICATION SETTINGS
# =============================================================================

# Debug mode (true/false)
DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Flask secret key for session management (generate a random string)
SECRET_KEY=your-secret-key-here

# Server host and port
HOST=0.0.0.0
PORT=5000

# =============================================================================
# DIRECTORY SETTINGS
# =============================================================================

# Temporary files directory
TEMP_DIR=temp

# Output directory for results
OUTPUT_DIR=output

# =============================================================================
# FILE PROCESSING SETTINGS
# =============================================================================

# Maximum file size in MB
MAX_FILE_SIZE_MB=10

# Supported file formats (comma-separated)
SUPPORTED_FORMATS=.txt,.docx,.pdf,.jpg,.jpeg,.png,.tiff,.bmp,.gif

# =============================================================================
# OCR SETTINGS
# =============================================================================

# HandwritingOCR API key (required for image processing)
# Get your API key from: https://www.handwritingocr.com/
HANDWRITING_OCR_API_KEY=your-handwriting-ocr-api-key-here

# HandwritingOCR API URL (optional, uses default if not specified)
HANDWRITING_OCR_API_URL=https://www.handwritingocr.com/api/v3

# OCR confidence threshold (0.0 to 1.0)
OCR_CONFIDENCE_THRESHOLD=0.7

# OCR language code
OCR_LANGUAGE=en

# Auto-delete processed documents after N seconds (default: 24 hours)
HANDWRITING_OCR_DELETE_AFTER=86400

# =============================================================================
# LLM SETTINGS (DeepSeek API)
# =============================================================================

# DeepSeek API key (required for AI grading features)
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Cache settings
CACHE_TTL_HOURS=24
CACHE_MAX_SIZE_MB=100

# API timeout settings
API_TIMEOUT_SECONDS=30
API_MAX_RETRIES=3

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Enable CORS (true/false)
ENABLE_CORS=false

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Enable rate limiting (true/false)
ENABLE_RATE_LIMITING=true

# Rate limit: requests per minute
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable development features (true/false)
DEVELOPMENT_MODE=false

# Enable detailed error messages (true/false)
DETAILED_ERRORS=false

# Enable performance profiling (true/false)
ENABLE_PROFILING=false
